// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  MANAGER
  STAFF
}

enum LeaveType {
  CASUAL
  SICK
  UNPAID
  VACATION
  PERSONAL
  OTHER
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED  
}

enum AttendanceStatus {
  PRESENT
  LATE
  ABSENT
  HALF_DAY
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?
  role      Role     @default(STAFF)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  attendances Attendance[]
  leaves Leave[]
  reviewedLeaves Leave[]      @relation("LeaveReviewer")
}


model Attendance {
  id             String   @id @default(uuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  date           DateTime @default(now()) @db.Date
  checkIn        DateTime? 
  checkOut       DateTime?
  status         AttendanceStatus @default(PRESENT)
  totalHours     Float?
  workedMinutes  Int?
  isAutoClockOut Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  @@unique([userId, date])
}

model Leave {
  id String     @id @default(uuid())
  userId String
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  type LeaveType
  startDate DateTime @db.Date
  endDate DateTime @db.Date
  reason String?
  status LeaveStatus @default(PENDING)
  appliedOn DateTime @default(now()) @db.Date
  reviewedBy String?
  reviewer User?  @relation("LeaveReviewer", fields: [reviewedBy], references: [id])
  reviewedOn DateTime? @db.Date
  reviewedComment String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

